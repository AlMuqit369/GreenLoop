# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database
# Get this from MongoDB Atlas: Database -> Connect -> Drivers -> copy the connection string.
# Replace <username>, <password>, and cluster0.xxxxx with your actual values.
# URL-encode any special characters in the password (e.g. @ becomes %40).
# Add /greenloop before the "?" to select the database name.
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/greenloop?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=15m
JWT_COOKIE_EXPIRES_DAYS=1

JWT_REFRESH_SECRET=replace_this_with_a_different_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# Email (used for password reset links)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
EMAIL_FROM=noreply@greenloop.com
